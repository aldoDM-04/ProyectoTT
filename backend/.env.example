# ─────────────────────────────────────────
#  Configuración del servidor
# ─────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ─────────────────────────────────────────
#  Base de datos PostgreSQL
# ─────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=Tepozteco
DB_USER=postgres
DB_PASSWORD=

# ─────────────────────────────────────────
#  JWT
# ─────────────────────────────────────────
JWT_SECRET=cambia_este_secreto_muy_largo_y_seguro_2025
JWT_EXPIRES_IN=8h
JWT_REFRESH_SECRET=cambia_este_secreto_de_refresh_muy_largo_y_seguro_2025
JWT_REFRESH_EXPIRES_IN=7d

# ─────────────────────────────────────────
#  Subida de archivos
# ─────────────────────────────────────────
UPLOAD_DIR=uploads
MAX_FILE_SIZE_MB=50

# ─────────────────────────────────────────
#  CORS – origen del frontend Angular
# ─────────────────────────────────────────
CORS_ORIGIN=http://localhost:4200
